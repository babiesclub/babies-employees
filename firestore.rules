rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isSelf(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function affectsOnly(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }

    // USERS
    // Instructors may only update a small whitelist on their own doc (profile + push tokens).
    // role, salary rates, gardens, adminSignature, unlockedMonths, camps* — ADMIN ONLY.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin() || (
        isSelf(uid) && affectsOnly([
          'name','phone','email','tz','address','gender',
          'oneSignalSubscriptionIds','oneSignalSubscriptionId',
          'fcmToken','lastSeen','pushEnabled',
          'scheduleApprovedAt','scheduleApprovedBy'
        ])
      );
      allow delete: if isAdmin();
    }

    // GARDENS
    match /gardens/{gardenId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // RECORDS — instructors log their own attendance
    match /records/{recordId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // INVOICES — ADMIN ONLY
    match /invoices/{invoiceId} {
      allow read, write: if isAdmin();
    }

    // CONTRACTS — read own or admin, sign own, admin creates
    match /contracts/{contractId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.instructorUid == request.auth.uid);
      allow create: if isAdmin();
      allow update: if isAdmin() || (
        resource.data.instructorUid == request.auth.uid
        && resource.data.status == 'pending'
      );
      allow delete: if isAdmin();
    }

    // PERSONAL DOCS — sensitive PII (id card, bank confirmation)
    match /personalDocs/{docId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.instructorUid == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.instructorUid == request.auth.uid;
      allow update, delete: if isAdmin() || (
        resource.data.instructorUid == request.auth.uid
      );
    }

    // RECEIPTS — instructor writes own; admin reads all
    match /receipts/{docId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.instructorUid == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.instructorUid == request.auth.uid;
      allow update, delete: if isAdmin() || (
        resource.data.instructorUid == request.auth.uid
      );
    }

    // TASKS
    match /tasks/{taskId} {
      allow read, write: if isSignedIn();
    }

    // NOTIFICATIONS — recipients read their own; anyone signed-in may create
    match /notifications/{notifId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.recipientUid == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (
        resource.data.recipientUid == request.auth.uid
      );
    }

    // CHAT MESSAGES — participants + admin
    // Field is `threadUid` (the instructor whose thread this is), plus
    // `senderUid`. Instructor queries only her own thread via
    // .where('threadUid', '==', uid) — the get rule below matches per-doc.
    match /chatMessages/{msgId} {
      allow read: if isSignedIn() && (
        isAdmin()
        || resource.data.threadUid == request.auth.uid
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // WHATSAPP — ADMIN ONLY (both legacy and current naming)
    match /waConversations/{convId}   { allow read, write: if isAdmin(); }
    match /waMessages/{msgId}         { allow read, write: if isAdmin(); }
    match /whatsapp_conversations/{convId} { allow read, write: if isAdmin(); }
    match /whatsapp_messages/{msgId}       { allow read, write: if isAdmin(); }

    // TENDERS + COMPANY DOCS — ADMIN ONLY
    match /tenders/{docId}      { allow read, write: if isAdmin(); }
    match /companyDocs/{docId}  { allow read: if isSignedIn(); allow write: if isAdmin(); }

    // SETTINGS / SEND LOG / SCHEDULED NOTIFICATIONS / EXTERNAL SCHEDULES — ADMIN ONLY
    match /settings/{docId}             { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /sendLog/{docId}              { allow read, write: if isAdmin(); }
    match /customNotifications/{docId}  { allow read, write: if isAdmin(); }
    match /external_schedules/{docId}   { allow read, write: if isAdmin(); }
    match /regionRoutes/{docId}         { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /rotationGroups/{docId}       { allow read: if isSignedIn(); allow write: if isAdmin(); }

    // MATERIALS / WEEKLY SCHEDULE / ANIMALS — read all, write admin
    match /materials/{matId}        { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /weeklySchedule/{weekId}  { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /animals/{animalId}       { allow read: if isSignedIn(); allow write: if isAdmin(); }

    // CAMP SESSIONS — read/write for signed-in (self-service marking)
    match /camp_sessions/{sessId}   { allow read, write: if isSignedIn(); }
    match /camp_clients/{clientId}  { allow read: if isSignedIn(); allow write: if isAdmin(); }

    // SUBSTITUTE ASSIGNMENTS — admin manages, all read
    match /substituteAssignments/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ADMIN CALENDAR (הכשרות, פגישות, אירועים) — admin only
    match /adminCalendarEvents/{eventId} {
      allow read, write: if isAdmin();
    }

    // INSTRUCTOR REPORTS (monthly attendance PDF, published by admin)
    // Admin writes; instructor reads only her own docs.
    match /instructorReports/{reportId} {
      allow read: if isSignedIn() && (
        isAdmin()
        || resource.data.instructorUid == request.auth.uid
      );
      allow write: if isAdmin();
    }

    // SALARY PAYMENTS — admin-only. Tracks per-month payment status per instructor.
    // Not exposed to the instructor (she sees only the published instructorReports PDF).
    match /salaryPayments/{docId} {
      allow read, write: if isAdmin();
    }

    // META (gardens, animals lists, etc.) — read all, write admin
    match /meta/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // EMAIL IMPORTS (invoices/receipts pulled from Gmail) — ADMIN ONLY
    match /emailImports/{docId} {
      allow read, write: if isAdmin();
    }

    // GMAIL TOKENS (refresh_token per connected Gmail account) — ADMIN ONLY
    // Contains sensitive OAuth refresh_token; even read is admin-only.
    match /gmailTokens/{accountKey} {
      allow read, write: if isAdmin();
    }

    // GMAIL OAUTH STATE (short-lived CSRF nonces) — ADMIN ONLY
    match /gmailOAuthState/{nonce} {
      allow read, write: if isAdmin();
    }

    // FINAL DENY — anything not matched above is closed.
    // This replaces the previous permissive catch-all that allowed any signed-in user
    // to read/write unlisted collections (including sensitive ones we hadn't declared).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
