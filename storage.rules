rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Helper: is the calling user an admin (per Firestore users doc)?
    function isAdmin() {
      return request.auth != null
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Weekly lesson materials: instructors read, admins write.
    match /materials/{matId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Receipts uploaded by instructors and viewed by admins.
    match /receipts/{userId}/{allPaths=**} {
      allow read: if request.auth != null
        && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null
        && (request.auth.uid == userId || isAdmin());
    }

    // Personal docs (ID, police clearance, bank confirmation).
    match /personalDocs/{userId}/{allPaths=**} {
      allow read: if request.auth != null
        && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null
        && (request.auth.uid == userId || isAdmin());
    }

    // Signed contracts.
    match /contracts/{contractId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Animal info media (images / videos for the animals library).
    match /animals/{animalId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Company profile docs (CVs, insurance, syllabi, certificates) - admin only.
    match /company-docs/{docId}/{allPaths=**} {
      allow read, write: if isAdmin();
    }

    // Instructor monthly reports (PDF): admin uploads; instructor + admin can read.
    // Read via getDownloadURL token also works for the instructor without login.
    match /instructor-reports/{userId}/{allPaths=**} {
      allow read: if request.auth != null
        && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    // WhatsApp incoming media (images / videos / audio / documents).
    // The webhook Cloud Function writes via admin SDK (bypasses these rules).
    // Admin users need read access to view media in the inbox UI.
    // Public read via ?token= download URLs also works — the token itself is
    // effectively a capability (URLs are only shared with admins over HTTPS).
    match /whatsapp-media/{convPhone}/{allPaths=**} {
      allow read: if isAdmin();
      allow write: if false;  // only backend
    }

    // Default deny.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
